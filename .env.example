# 复制为 .env 后填写真实值，勿提交 .env 到 Git
# 本地：edgeone pages dev  会读取本目录 .env

# --- Dify（必填）---
DIFY_API_KEY=
# 自建 Dify 时修改，默认 https://api.dify.ai
# DIFY_API_URL=https://api.dify.ai

# 工作流输入字段映射（与 Dify 开始节点变量名不一致时取消注释并修改）
# DIFY_INPUT_RESUME_TEXT=resume_str
# DIFY_INPUT_JD_TEXT=job_desc
# DIFY_INPUT_RESUME_FILE=resume_file
# DIFY_INPUT_JD_FILE=jd_file

# 工作流输出字段映射
# DIFY_OUTPUT_TEXT=resume_text
# DIFY_OUTPUT_HTML=resume_html
# DIFY_OUTPUT_SUGGESTIONS=suggestions
# DIFY_OUTPUT_ANALYSIS=analyse
# DIFY_OUTPUT_MATCH=matchScore
# DIFY_OUTPUT_CHANGELOG=modificationPoints

# DIFY_DEFAULT_USER=resume-promote-web

# --- CORS ---
# 本地开发可保持 *；上线改为站点 Origin，如 https://your-domain.com
CORS_ORIGIN=*

# --- 上传与文本限额（留空则用代码默认值）---
# MAX_FILE_BYTES=5242880
# MAX_RESUME_TEXT_CHARS=2800
# MAX_JD_TEXT_CHARS=1000
# MAX_REQUEST_BYTES=12582912

# --- KV 限流（本地一般关闭；生产在 Pages 控制台绑定 KV 后启用）---
RATE_LIMIT_ENABLED=false
# RATE_LIMIT_KV_BINDING=RESUME_PROMOTE_KV
# RATE_LIMIT_KEY_PREFIX=optimize
# RATE_LIMIT_WINDOW_SEC=3600
# RATE_LIMIT_IP_MAX_REQUESTS=10
# RATE_LIMIT_IP_WINDOW_SEC=3600
# RATE_LIMIT_GLOBAL_MAX_REQUESTS=0
# RATE_LIMIT_GLOBAL_WINDOW_SEC=3600
# KV 异常时是否放行（本地默认 true）
# RATE_LIMIT_FAIL_OPEN=true
